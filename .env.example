# Secret used to sign session cookies (JWT). Generate a random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-secret

# Optional: GPT API for prompt generation / future image tooling
OPENAI_API_KEY=your_openai_api_key

# Local ComfyUI / SD endpoints
COMFYUI_BASE_URL=http://127.0.0.1:8189
COMFYUI_INPUT_DIR=/Users/yourname/clawd/projects/ComfyUI/input
SD_BASE_URL=http://127.0.0.1:7860

# Optional local LLM expansion / local vision QC
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_QC_MODEL=qwen3-vl:4b

# Optional model path hints for your own reference
COMFYUI_CHECKPOINT_DIR=/Users/yourname/clawd/projects/ComfyUI/models/checkpoints
COMFYUI_CONTROLNET_DIR=/Users/yourname/clawd/projects/ComfyUI/models/controlnet
COMFYUI_IPADAPTER_DIR=/Users/yourname/clawd/projects/ComfyUI/models/ipadapter
COMFYUI_LORA_DIR=/Users/yourname/clawd/projects/ComfyUI/models/loras
COMFYUI_CLIP_VISION_DIR=/Users/yourname/clawd/projects/ComfyUI/models/clip_vision
